{
  "name": "@vidro/plugin",
  "version": "0.0.0",
  "description": "Vite plugins for the Vidro framework (JSX transform and future tooling)",
  "license": "MIT",
  "files": [
    "dist",
    "tsconfig.base.json"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack --dts",
    "dev": "vp pack --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@types/babel__generator": "catalog:",
    "@types/babel__traverse": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vidro/router": "workspace:*",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@vidro/router": "workspace:*",
    "vite-plus": "catalog:"
  }
}
